<!-- jsPDF for PDF generation -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>

<style>
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap');

:root {
  --cream: #F5F0E8;
  --beige: #E8DDD0;
  --beige-mid: #D4C4B0;
  --brown-light: #A08060;
  --brown: #7A5C3E;
  --brown-dark: #4A3525;
  --text: #2E1F0F;
  --text-mid: #6B5040;
  --white: #FDFAF6;
  --border: #C8B89A;
  --success: #5C7A5E;
  --error: #8B3A3A;
  --shadow: 0 2px 20px rgba(74,53,37,0.08);
  --radius: 8px;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Jost', sans-serif;
  background: var(--cream);
  color: var(--text);
  min-height: 100vh;
  font-size: 14px;
  font-weight: 300;
}

h1,h2,h3,h4,h5 {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 500;
  letter-spacing: 0.02em;
}

/* ─── NAVBAR ─── */
.navbar {
  background: var(--brown-dark);
  padding: 0 32px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 60px;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 12px rgba(0,0,0,0.2);
}
.navbar-brand {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px;
  color: var(--beige);
  letter-spacing: 0.08em;
  font-weight: 300;
}
.navbar-brand span { color: var(--brown-light); }
.nav-links { display: flex; gap: 8px; }
.nav-btn {
  background: none;
  border: 1px solid transparent;
  color: var(--beige-mid);
  padding: 6px 16px;
  border-radius: 4px;
  cursor: pointer;
  font-family: 'Jost', sans-serif;
  font-size: 13px;
  font-weight: 300;
  letter-spacing: 0.05em;
  transition: all 0.2s;
}
.nav-btn:hover, .nav-btn.active {
  border-color: var(--brown-light);
  color: var(--beige);
  background: rgba(160,128,96,0.15);
}

/* ─── PAGES ─── */
.page { display: none; padding: 32px; max-width: 1100px; margin: 0 auto; }
.page.active { display: block; }

/* ─── DASHBOARD ─── */
.dashboard-hero {
  text-align: center;
  padding: 48px 0 32px;
}
.dashboard-hero h1 {
  font-size: 42px;
  color: var(--brown-dark);
  margin-bottom: 8px;
}
.dashboard-hero p {
  color: var(--text-mid);
  font-size: 15px;
  letter-spacing: 0.04em;
}
.consult-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 16px;
  margin: 32px 0;
}
.consult-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 24px 20px;
  cursor: pointer;
  transition: all 0.25s;
  text-align: center;
  box-shadow: var(--shadow);
}
.consult-card:hover {
  border-color: var(--brown);
  transform: translateY(-2px);
  box-shadow: 0 6px 24px rgba(74,53,37,0.14);
}
.consult-card .icon { font-size: 28px; margin-bottom: 12px; }
.consult-card h3 { font-size: 16px; color: var(--brown-dark); margin-bottom: 6px; }
.consult-card p { font-size: 12px; color: var(--text-mid); line-height: 1.5; }
.section-title {
  font-size: 26px;
  color: var(--brown-dark);
  margin-bottom: 20px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--border);
}

/* ─── PATIENT LIST ─── */
.patient-row {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 14px 20px;
  margin-bottom: 10px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  transition: border-color 0.2s;
}
.patient-row:hover { border-color: var(--brown); }
.patient-row .info { flex: 1; }
.patient-row .name { font-size: 15px; font-weight: 500; color: var(--brown-dark); }
.patient-row .meta { font-size: 12px; color: var(--text-mid); margin-top: 2px; }
.patient-row .actions { display: flex; gap: 8px; }

/* ─── FORM ─── */
.form-container {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 32px;
  box-shadow: var(--shadow);
}
.form-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 28px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--border);
}
.form-header h2 { font-size: 28px; color: var(--brown-dark); }
.form-header p { font-size: 13px; color: var(--text-mid); margin-top: 4px; }
.form-section {
  margin-bottom: 32px;
}
.form-section h4 {
  font-size: 18px;
  color: var(--brown);
  margin-bottom: 16px;
  padding-bottom: 8px;
  border-bottom: 1px solid var(--beige);
  letter-spacing: 0.04em;
}
.form-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 16px;
}
.form-grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
.form-grid.cols-2 { grid-template-columns: repeat(2, 1fr); }
.form-group { display: flex; flex-direction: column; gap: 5px; }
.form-group.full { grid-column: 1 / -1; }
label {
  font-size: 12px;
  color: var(--text-mid);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  font-weight: 400;
}
label .req { color: var(--brown); }
input, select, textarea {
  border: 1px solid var(--border);
  background: var(--cream);
  border-radius: 4px;
  padding: 9px 12px;
  font-family: 'Jost', sans-serif;
  font-size: 14px;
  font-weight: 300;
  color: var(--text);
  outline: none;
  transition: border-color 0.2s;
}
input:focus, select:focus, textarea:focus {
  border-color: var(--brown);
  background: var(--white);
}
textarea { resize: vertical; min-height: 80px; }
select { cursor: pointer; }

/* ─── CALC SECTION ─── */
.calc-box {
  background: var(--beige);
  border: 1px solid var(--beige-mid);
  border-radius: var(--radius);
  padding: 24px;
  margin-top: 12px;
}
.calc-box h4 { font-size: 18px; color: var(--brown-dark); margin-bottom: 16px; }
.calc-results {
  background: var(--brown-dark);
  color: var(--beige);
  border-radius: var(--radius);
  padding: 20px 24px;
  margin-top: 20px;
  display: none;
}
.calc-results.show { display: block; }
.calc-results h5 { font-family: 'Cormorant Garamond', serif; font-size: 20px; margin-bottom: 14px; color: var(--beige); }
.result-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  font-size: 13px;
}
.result-row:last-child { border-bottom: none; }
.result-row .label { color: var(--beige-mid); }
.result-row .value { font-weight: 500; font-size: 15px; color: var(--white); }
.result-row .badge {
  background: var(--brown-light);
  color: var(--white);
  padding: 2px 10px;
  border-radius: 20px;
  font-size: 11px;
  letter-spacing: 0.04em;
}

/* ─── BUTTONS ─── */
.btn {
  border: none;
  border-radius: 4px;
  padding: 10px 22px;
  cursor: pointer;
  font-family: 'Jost', sans-serif;
  font-size: 13px;
  font-weight: 400;
  letter-spacing: 0.06em;
  transition: all 0.2s;
}
.btn-primary {
  background: var(--brown);
  color: var(--white);
}
.btn-primary:hover { background: var(--brown-dark); }
.btn-secondary {
  background: var(--beige);
  color: var(--brown-dark);
  border: 1px solid var(--border);
}
.btn-secondary:hover { background: var(--beige-mid); }
.btn-danger { background: var(--error); color: var(--white); }
.btn-success { background: var(--success); color: var(--white); }
.btn-pdf {
  background: var(--brown-dark);
  color: var(--beige);
}
.btn-pdf:hover { background: var(--brown); }
.btn-sm { padding: 6px 14px; font-size: 12px; }

.btn-row {
  display: flex;
  gap: 12px;
  margin-top: 28px;
  flex-wrap: wrap;
  align-items: center;
}

/* ─── DIET PLANNER ─── */
.diet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}
.meal-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  margin-bottom: 16px;
  overflow: hidden;
}
.meal-header {
  background: var(--brown-dark);
  color: var(--beige);
  padding: 12px 20px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
}
.meal-header h4 { font-family: 'Cormorant Garamond', serif; font-size: 17px; }
.meal-header .kcal-badge { font-size: 12px; color: var(--beige-mid); }
.meal-body { padding: 16px; }
.food-row {
  display: grid;
  grid-template-columns: 2fr 80px 80px 1fr 32px;
  gap: 8px;
  align-items: center;
  margin-bottom: 8px;
}
.food-row input { padding: 6px 8px; font-size: 13px; }
.food-total {
  text-align: right;
  font-size: 12px;
  color: var(--text-mid);
  padding-top: 8px;
  border-top: 1px solid var(--beige);
}
.add-food-btn {
  background: none;
  border: 1px dashed var(--border);
  color: var(--text-mid);
  border-radius: 4px;
  padding: 7px 14px;
  font-size: 12px;
  cursor: pointer;
  width: 100%;
  font-family: 'Jost', sans-serif;
  transition: all 0.2s;
}
.add-food-btn:hover { border-color: var(--brown); color: var(--brown); }
.diet-summary {
  background: var(--brown-dark);
  color: var(--beige);
  border-radius: var(--radius);
  padding: 20px 24px;
  display: flex;
  justify-content: space-around;
  margin-bottom: 20px;
  flex-wrap: wrap;
  gap: 16px;
}
.diet-summary-item { text-align: center; }
.diet-summary-item .sv { font-size: 22px; font-family: 'Cormorant Garamond', serif; }
.diet-summary-item .sl { font-size: 11px; color: var(--beige-mid); letter-spacing: 0.05em; text-transform: uppercase; margin-top: 2px; }

/* ─── TOAST ─── */
.toast {
  position: fixed;
  bottom: 24px;
  right: 24px;
  background: var(--brown-dark);
  color: var(--beige);
  padding: 12px 24px;
  border-radius: var(--radius);
  font-size: 13px;
  z-index: 9999;
  opacity: 0;
  transform: translateY(10px);
  transition: all 0.3s;
  pointer-events: none;
}
.toast.show { opacity: 1; transform: translateY(0); }

/* ─── MODAL ─── */
.modal-overlay {
  position: fixed; inset: 0;
  background: rgba(46,31,15,0.6);
  z-index: 500;
  display: none;
  align-items: center;
  justify-content: center;
}
.modal-overlay.show { display: flex; }
.modal {
  background: var(--white);
  border-radius: var(--radius);
  padding: 32px;
  max-width: 500px;
  width: 90%;
  box-shadow: 0 20px 60px rgba(0,0,0,0.3);
}
.modal h3 { font-size: 22px; color: var(--brown-dark); margin-bottom: 12px; }
.modal p { color: var(--text-mid); margin-bottom: 20px; font-size: 14px; }

/* ─── SEARCH ─── */
.search-bar {
  width: 100%;
  padding: 10px 16px;
  border: 1px solid var(--border);
  border-radius: 4px;
  background: var(--white);
  font-family: 'Jost', sans-serif;
  font-size: 14px;
  margin-bottom: 20px;
  outline: none;
  color: var(--text);
}
.search-bar:focus { border-color: var(--brown); }

/* ─── TAGS ─── */
.tag {
  display: inline-block;
  background: var(--beige);
  color: var(--brown);
  border: 1px solid var(--beige-mid);
  border-radius: 20px;
  padding: 2px 10px;
  font-size: 11px;
  letter-spacing: 0.04em;
  margin: 2px;
}
.tag.green { background: #E8F0E8; color: var(--success); border-color: #C0D4C0; }
.tag.red { background: #F0E8E8; color: var(--error); border-color: #D4C0C0; }

/* ─── MISC ─── */
.empty-state {
  text-align: center;
  padding: 48px 20px;
  color: var(--text-mid);
}
.empty-state .icon { font-size: 40px; margin-bottom: 12px; }
.empty-state h3 { font-size: 20px; margin-bottom: 8px; color: var(--brown); }
.divider { border: none; border-top: 1px solid var(--border); margin: 24px 0; }
.checkbox-group { display: flex; flex-wrap: wrap; gap: 8px; }
.checkbox-item {
  display: flex;
  align-items: center;
  gap: 6px;
  background: var(--cream);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 6px 12px;
  cursor: pointer;
  font-size: 13px;
  transition: all 0.2s;
}
.checkbox-item:hover { border-color: var(--brown); }
.checkbox-item input[type=checkbox] { accent-color: var(--brown); }
.radio-group { display: flex; flex-wrap: wrap; gap: 8px; }
.radio-item {
  display: flex;
  align-items: center;
  gap: 6px;
  background: var(--cream);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 7px 14px;
  cursor: pointer;
  font-size: 13px;
  transition: all 0.2s;
}
.radio-item input[type=radio] { accent-color: var(--brown); }
.info-badge {
  display: inline-block;
  background: var(--beige);
  border: 1px solid var(--beige-mid);
  border-radius: 4px;
  padding: 4px 10px;
  font-size: 12px;
  color: var(--text-mid);
  margin-bottom: 8px;
}
@media (max-width: 768px) {
  .form-grid { grid-template-columns: 1fr; }
  .form-grid.cols-3, .form-grid.cols-2 { grid-template-columns: 1fr; }
  .food-row { grid-template-columns: 1fr 70px 70px; }
  .food-row input:nth-child(4), .food-row button { display: none; }
  .page { padding: 16px; }
  .navbar { padding: 0 16px; }
  .consult-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar">
  <div class="navbar-brand">Nutri<span>Consulta</span></div>
  <div class="nav-links">
    <button class="nav-btn active" onclick="showPage('dashboard')">Início</button>
    <button class="nav-btn" onclick="showPage('pacientes')">Pacientes</button>
    <button class="nav-btn" onclick="showPage('dieta')">Plano Alimentar</button>
  </div>
</nav>

<!-- ════════════════════════════════ DASHBOARD ════════════════════════════════ -->
<div id="page-dashboard" class="page active">
  <div class="dashboard-hero">
    <h1>Olá, Nutricionista 🌿</h1>
    <p>Selecione o tipo de consulta para iniciar o atendimento</p>
  </div>

  <div class="consult-grid">
    <div class="consult-card" onclick="startConsult('1a_consulta')">
      <div class="icon">🌱</div>
      <h3>1ª Consulta Padrão</h3>
      <p>Anamnese completa · 45 min · Todos os perfis adultos</p>
    </div>
    <div class="consult-card" onclick="startConsult('2a_consulta')">
      <div class="icon">📋</div>
      <h3>2ª Consulta</h3>
      <p>Acompanhamento · Revisão do plano · Evolução</p>
    </div>
    <div class="consult-card" onclick="startConsult('3a_consulta')">
      <div class="icon">📈</div>
      <h3>3ª Consulta</h3>
      <p>Ajustes finos · Manutenção · Objetivos alcançados</p>
    </div>
    <div class="consult-card" onclick="startConsult('idosos')">
      <div class="icon">🤍</div>
      <h3>1ª Consulta Idosos</h3>
      <p>Protocolo geriátrico · 60+ anos · IMC específico</p>
    </div>
    <div class="consult-card" onclick="startConsult('estetica')">
      <div class="icon">✨</div>
      <h3>Nutrição Estética</h3>
      <p>Pele, cabelo, unhas · Composição corporal · Antioxidantes</p>
    </div>
  </div>

  <h2 class="section-title">Últimos Atendimentos</h2>
  <div id="recent-patients">
    <div class="empty-state"><div class="icon">📂</div><h3>Nenhum atendimento ainda</h3><p>Inicie uma consulta acima para começar</p></div>
  </div>
</div>

<!-- ════════════════════════════════ PACIENTES ════════════════════════════════ -->
<div id="page-pacientes" class="page">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
    <h2 class="section-title" style="margin:0;border:none;">Pacientes</h2>
  </div>
  <input type="text" class="search-bar" placeholder="Buscar paciente por nome..." oninput="filterPatients(this.value)">
  <div id="patient-list">
    <div class="empty-state"><div class="icon">👤</div><h3>Nenhum paciente cadastrado</h3><p>Inicie uma consulta para cadastrar</p></div>
  </div>
</div>

<!-- ════════════════════════════════ FORMULÁRIO ════════════════════════════════ -->
<div id="page-form" class="page">
  <div id="form-content"></div>
</div>

<!-- ════════════════════════════════ DIETA ════════════════════════════════ -->
<div id="page-dieta" class="page">
  <div class="diet-header">
    <h2 class="section-title" style="margin:0;border:none;">Plano Alimentar</h2>
    <div style="display:flex;gap:10px;">
      <select id="diet-patient-select" onchange="loadPatientForDiet()" style="padding:8px 12px;">
        <option value="">— Selecionar Paciente —</option>
      </select>
      <button class="btn btn-pdf" onclick="exportDietPDF()">⬇ Exportar PDF</button>
    </div>
  </div>

  <div id="patient-diet-info" style="display:none;" class="form-container" style="margin-bottom:20px;">
    <div class="form-grid cols-3">
      <div><label>Paciente</label><div id="di-nome" style="font-size:16px;font-weight:500;color:var(--brown-dark);margin-top:4px;"></div></div>
      <div><label>Meta Calórica (GET)</label><div id="di-get" style="font-size:16px;color:var(--brown);margin-top:4px;"></div></div>
      <div><label>Meta Ajustada</label><div id="di-meta" style="font-size:16px;color:var(--success);margin-top:4px;"></div></div>
    </div>
    <div style="margin-top:12px;">
      <label>Restrições / Preferências</label>
      <div id="di-obs" style="font-size:13px;color:var(--text-mid);margin-top:4px;"></div>
    </div>
  </div>

  <div class="diet-summary" id="diet-macro-bar">
    <div class="diet-summary-item"><div class="sv" id="dm-kcal">0</div><div class="sl">kcal total</div></div>
    <div class="diet-summary-item"><div class="sv" id="dm-cho">0g</div><div class="sl">Carboidratos</div></div>
    <div class="diet-summary-item"><div class="sv" id="dm-ptn">0g</div><div class="sl">Proteínas</div></div>
    <div class="diet-summary-item"><div class="sv" id="dm-lip">0g</div><div class="sl">Lipídios</div></div>
    <div class="diet-summary-item"><div class="sv" id="dm-fiber">0g</div><div class="sl">Fibras</div></div>
  </div>

  <div id="meals-container"></div>

  <button class="btn btn-secondary" onclick="addMeal()" style="width:100%;margin-bottom:16px;">+ Adicionar Refeição</button>
  <div class="btn-row">
