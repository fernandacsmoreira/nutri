function lookupBodyFatPercent(pregas, sexo, idade) {
  const col = parseInt(idade) < 30 ? '17-29' : (parseInt(idade) < 40 ? '30-39' : (parseInt(idade) < 50 ? '40-49' : '50+'));
  // Simple interpolation from table
  const vals_H = [4.8,8.1,10.5,12.9,14.7,16.4,17.7,19.0,20.1,21.2,22.2,23.1,24.0,24.8,25.5,26.2,26.9,27.6,28.2,28.8,29.4,30.0,30.5,31.0,31.5,32.0,32.5,32.9,33.3,33.7,34.1,34.5,34.9,35.3,35.6,35.9];
  const vals_M_young = [10.5,14.1,16.8,19.5,21.5,23.4,25.0,26.5,27.8,29.1,30.2,31.2,32.2,33.1,34.0,35.6,36.4,37.1,37.8,38.4,39.0,39.6,40.2,40.8,41.3,41.8,42.3,42.8,43.3,43.7,44.1,44.4,44.8,45.2,45.6,45.9];
  // pregas start from 15, step 5
  const idx = Math.round((pregas - 15) / 5);
  const safeIdx = Math.max(0, Math.min(idx, vals_H.length - 1));
  if (sexo === 'M') return vals_H[safeIdx];
  return vals_M_young[safeIdx];
}

function autoCalc(show=false) {
  const peso = parseFloat(document.getElementById('f-peso')?.value);
  const altura = parseFloat(document.getElementById('f-altura')?.value);
  const sono = parseFloat(document.getElementById('f-sono')?.value || 0);
  const hAtiv = parseFloat(document.getElementById('f-h_atividade')?.value || 0);
  const intensidade = document.getElementById('f-intensidade')?.value;
  const metodo = document.getElementById('f-metodo_calc')?.value || 'harris';
  const objetivo = document.getElementById('f-objetivo')?.value || 'manutencao';
  const sexo = document.getElementById('f-sexo')?.value;
  const idade = parseFloat(document.getElementById('f-idade')?.value || 30);
  const cintura = parseFloat(document.getElementById('f-cintura')?.value || 0);
  const quadril = parseFloat(document.getElementById('f-quadril')?.value || 0);
  const pregas = parseFloat(document.getElementById('f-pregas')?.value || 0);

  if (!peso || !altura) return;

  // IMC
  const imc = peso / ((altura/100) ** 2);
  const imcClass = classifyIMC(imc, idade);

  // TMB
  let tmb = 0;
  if (metodo === 'harris') {
    if (sexo === 'F') tmb = 655.1 + (9.6*peso) + (1.8*altura) - (4.7*idade);
    else tmb = 66.5 + (13.8*peso) + (5*altura) - (6.8*idade);
  } else { // FAO/OMS
    if (sexo === 'F') {
      if (idade <= 30) tmb = 14.818*peso + 486.6;
      else if (idade <= 60) tmb = 8.126*peso + 845.6;
      else tmb = 9.082*peso + 658.5;
    } else {
      if (idade <= 30) tmb = 15.057*peso + 692.2;
      else if (idade <= 60) tmb = 11.472*peso + 873.1;
      else tmb = 11.711*peso + 587.7;
    }
  }

  // GET pelo método VENTA (Ve1 + Ve2)
  const hRotina = 24 - sono;
  const fatorAtiv = getFatorAtividade(sexo, intensidade);
  const tmb24 = tmb / 24;
  const ve1 = tmb24 * sono;
  const ve2 = tmb24 * hRotina * fatorAtiv;
  const vet = ve1 + ve2;
  const vetTermico = vet * 1.1;

  // Meta
  const { delta, label } = getObjetivoDelta(objetivo);
  const meta = vetTermico + delta;

  // % Gordura
  let gordura = null, gorduraClass = '';
  if (pregas >= 15) {
    gordura = lookupBodyFatPercent(pregas, sexo, idade);
    gorduraClass = classifyGordura(gordura, sexo);
  }

  // RCQ
  let rcq = null, rcqClass = '';
  if (cintura && quadril) {
    rcq = cintura / quadril;
    rcqClass = classifyRCQ(rcq, sexo);
  }

  // Populate results
  set('r-imc', imc.toFixed(1));
  set('r-imc-class', imcClass);
  set('r-tmb', Math.round(tmb));
  set('r-get', Math.round(vet));
  set('r-vet-termico', Math.round(vetTermico));
  set('r-meta', Math.round(meta));
  set('r-meta-tipo', label);
  set('r-gordura', gordura ? gordura.toFixed(1) + '%' : '—');
  set('r-gordura-class', gordura ? gorduraClass : '');
  set('r-rcq', rcq ? rcq.toFixed(2) : '—');
  set('r-rcq-class', rcq ? rcqClass : '');

  const res = document.getElementById('calc-results');
  if (res) res.classList.add('show');
  if (show) toast('✅ Cálculo realizado!');

  // Store for diet
  window._lastCalc = { imc, imcClass, tmb, vet, vetTermico, meta, gordura, gorduraClass, rcq, rcqClass };
}

function set(id, val) {
  const el = document.getElementById(id);
  if (el) el.textContent = val;
}

function getFatorAtividade(sexo, intensidade) {
  const map = {
    F: { leve:1.56, moderada:1.64, intensa:1.82 },
    M: { leve:1.55, moderada:1.78, intensa:2.10 }
  };
  return (map[sexo||'F']?.[intensidade]) || 1.56;
}

function getObjetivoDelta(obj) {
  const map = {
    manutencao: { delta:0, label:'Manutenção' },
    perda_1: { delta:-256, label:'−1kg/mês' },
    perda_15: { delta:-384, label:'−1,5kg/mês' },
    perda_2: { delta:-513, label:'−2kg/mês' },
    perda_25: { delta:-641, label:'−2,5kg/mês' },
    perda_3: { delta:-770, label:'−3kg/mês' },
    ganho_05: { delta:250, label:'+0,5kg/mês' },
    ganho_1: { delta:500, label:'+1kg/mês' }
  };
  return map[obj] || { delta:0, label:'Manutenção' };
}

function classifyIMC(imc, idade) {
  if (idade >= 60) {
    if (imc < 22) return 'Magreza';
    if (imc <= 27) return 'Eutrofia';
    return 'Obesidade';
  }
  if (imc < 16) return 'Magreza G3';
  if (imc < 17) return 'Magreza G2';
  if (imc < 18.5) return 'Magreza G1';
  if (imc < 25) return 'Eutrofia';
  if (imc < 30) return 'Sobrepeso';
  if (imc < 35) return 'Obesidade G1';
  if (imc < 40) return 'Obesidade G2';
  return 'Obesidade G3';
}

function classifyGordura(g, sexo) {
  if (sexo === 'M') {
    if (g < 8) return 'Magro';
    if (g <= 15) return 'Ótimo';
    if (g <= 20) return 'Leve adiposidade';
    if (g <= 24) return 'Adiposidade';
    return 'Obesidade';
  } else {
    if (g < 13) return 'Magra';
    if (g <= 23) return 'Ótimo';
    if (g <= 27) return 'Leve adiposidade';
    if (g <= 32) return 'Adiposidade';
    return 'Obesidade';
  }
}

function classifyRCQ(rcq, sexo) {
  const limit = sexo === 'M' ? 1.0 : 0.85;
  return rcq > limit ? 'Risco cardiovascular' : 'Sem risco';
}

