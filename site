<script>
// ══════════════════════════════════════════════
// STATE
// ══════════════════════════════════════════════
let currentConsultType = '';
let currentPatientId = null;
let allPatients = [];
let mealsData = [];
let db, fbFns;

window.addEventListener('firebaseReady', () => {
  db = window._db;
  fbFns = window._fbFns;
  loadAllPatients();
});

// ══════════════════════════════════════════════
// NAVIGATION
// ══════════════════════════════════════════════
function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  const btns = document.querySelectorAll('.nav-btn');
  const labels = ['dashboard','pacientes','dieta'];
  const idx = labels.indexOf(name);
  if (idx >= 0) btns[idx].classList.add('active');
  if (name === 'dieta') populateDietPatientSelect();
}

// ══════════════════════════════════════════════
// TOAST
// ══════════════════════════════════════════════
function toast(msg, dur=3000) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), dur);
}

// ══════════════════════════════════════════════
// MODAL
// ══════════════════════════════════════════════
let modalCb = null;
function confirmModal(title, msg, cb) {
  document.getElementById('modal-title').textContent = title;
  document.getElementById('modal-msg').textContent = msg;
  modalCb = cb;
  document.getElementById('modal-overlay').classList.add('show');
  document.getElementById('modal-confirm-btn').onclick = () => { closeModal(); if(modalCb) modalCb(); };
}
function closeModal() { document.getElementById('modal-overlay').classList.remove('show'); }

// ══════════════════════════════════════════════
// FIREBASE HELPERS
// ══════════════════════════════════════════════
async function savePatient(data) {
  if (!db) { toast('⚠️ Firebase não conectado. Configure o firebaseConfig.'); return null; }
  try {
    if (currentPatientId) {
      const ref = fbFns.doc(db, 'pacientes', currentPatientId);
      await fbFns.updateDoc(ref, { ...data, updatedAt: new Date().toISOString() });
      toast('✅ Consulta atualizada!');
      return currentPatientId;
    } else {
      const ref = await fbFns.addDoc(fbFns.collection(db, 'pacientes'), { ...data, createdAt: new Date().toISOString() });
      toast('✅ Consulta salva!');
      return ref.id;
    }
  } catch(e) {
    console.error(e);
    toast('❌ Erro ao salvar. Verifique o Firebase.');
    return null;
  }
}

async function loadAllPatients() {
  if (!db) return;
  try {
    const q = fbFns.query(fbFns.collection(db, 'pacientes'), fbFns.orderBy('createdAt', 'desc'));
    const snap = await fbFns.getDocs(q);
    allPatients = snap.docs.map(d => ({ id: d.id, ...d.data() }));
    renderPatientList(allPatients);
    renderRecentPatients(allPatients.slice(0,3));
  } catch(e) { console.error(e); }
}

async function deletePatient(id) {
  if (!db) return;
  try {
    await fbFns.deleteDoc(fbFns.doc(db, 'pacientes', id));
    toast('🗑 Paciente removido');
    loadAllPatients();
  } catch(e) { toast('❌ Erro ao remover'); }
}

// ══════════════════════════════════════════════
// PATIENT LIST
// ══════════════════════════════════════════════
function renderPatientList(list) {
  const el = document.getElementById('patient-list');
  if (!list.length) {
    el.innerHTML = '<div class="empty-state"><div class="icon">👤</div><h3>Nenhum paciente</h3><p>Inicie uma consulta para cadastrar</p></div>';
    return;
  }
  el.innerHTML = list.map(p => `
    <div class="patient-row">
      <div class="info" onclick="openPatient('${p.id}')">
        <div class="name">${p.nome || 'Sem nome'}</div>
        <div class="meta">
          <span class="tag">${consultLabel(p.tipo)}</span>
          ${p.idade ? `<span class="tag">${p.idade} anos</span>` : ''}
          ${p.objetivo ? `<span class="tag green">${p.objetivo}</span>` : ''}
          <span style="font-size:11px;color:var(--text-mid);margin-left:8px;">${formatDate(p.createdAt)}</span>
        </div>
      </div>
      <div class="actions">
        <button class="btn btn-secondary btn-sm" onclick="openPatient('${p.id}')">Ver</button>
        <button class="btn btn-pdf btn-sm" onclick="generateConsultPDF('${p.id}')">PDF</button>
        <button class="btn btn-danger btn-sm" onclick="confirmDeletePatient('${p.id}')">×</button>
      </div>
    </div>
  `).join('');
}

function renderRecentPatients(list) {
  const el = document.getElementById('recent-patients');
  if (!list.length) return;
  el.innerHTML = list.map(p => `
    <div class="patient-row">
      <div class="info" onclick="openPatient('${p.id}')">
        <div class="name">${p.nome || 'Sem nome'}</div>
        <div class="meta"><span class="tag">${consultLabel(p.tipo)}</span> ${formatDate(p.createdAt)}</div>
      </div>
      <div class="actions">
        <button class="btn btn-secondary btn-sm" onclick="openPatient('${p.id}')">Abrir</button>
        <button class="btn btn-pdf btn-sm" onclick="generateConsultPDF('${p.id}')">PDF</button>
      </div>
    </div>
  `).join('');
}

function filterPatients(v) {
  const filtered = allPatients.filter(p => (p.nome||'').toLowerCase().includes(v.toLowerCase()));
  renderPatientList(filtered);
}

function confirmDeletePatient(id) {
  confirmModal('Remover paciente', 'Esta ação não pode ser desfeita.', () => deletePatient(id));
}

function consultLabel(tipo) {
  const map = { '1a_consulta':'1ª Consulta', '2a_consulta':'2ª Consulta', '3a_consulta':'3ª Consulta', 'idosos':'Idosos', 'estetica':'Estética' };
  return map[tipo] || tipo;
}
function formatDate(iso) {
  if (!iso) return '';
  try { return new Date(iso).toLocaleDateString('pt-BR'); } catch { return ''; }
}

async function openPatient(id) {
  if (!db) return;
  const ref = fbFns.doc(db, 'pacientes', id);
  const snap = await fbFns.getDoc(ref);
  if (!snap.exists()) return;
  const data = { id: snap.id, ...snap.data() };
  currentPatientId = id;
  currentConsultType = data.tipo;
  showPage('form');
  renderForm(data.tipo, data);
}

// ══════════════════════════════════════════════
// START CONSULT
// ══════════════════════════════════════════════
function startConsult(tipo) {
  currentConsultType = tipo;
  currentPatientId = null;
  showPage('form');
  renderForm(tipo, {});
}

// ══════════════════════════════════════════════
// FORM RENDERER
// ══════════════════════════════════════════════
function renderForm(tipo, data) {
  const el = document.getElementById('form-content');
  const labels = { '1a_consulta':'1ª Consulta — Anamnese Completa', '2a_consulta':'2ª Consulta — Acompanhamento', '3a_consulta':'3ª Consulta — Reavaliação e Manutenção', 'idosos':'1ª Consulta — Protocolo Geriátrico', 'estetica':'Consulta de Nutrição Estética' };
  const subs = { '1a_consulta':'Anamnese completa · 45 min', '2a_consulta':'Revisão do plano alimentar e evolução', '3a_consulta':'Ajustes e consolidação do tratamento', 'idosos':'Protocolo específico para pacientes 60+ anos', 'estetica':'Foco em pele, cabelo, unhas e composição corporal' };

  let formHtml = `
    <div class="form-container">
      <div class="form-header">
        <div>
          <h2>${labels[tipo]}</h2>
          <p>${subs[tipo]}</p>
        </div>
        <button class="btn btn-secondary" onclick="showPage('dashboard')">← Voltar</button>
      </div>
  `;

  formHtml += formSectionIdentificacao(data);

  if (tipo === '1a_consulta') formHtml += form1aConsulta(data);
  else if (tipo === '2a_consulta') formHtml += form2aConsulta(data);
  else if (tipo === '3a_consulta') formHtml += form3aConsulta(data);
  else if (tipo === 'idosos') formHtml += formIdosos(data);
  else if (tipo === 'estetica') formHtml += formEstetica(data);

  formHtml += formCalculoSection(data, tipo);
  formHtml += formObjetivosSection(data);

  formHtml += `
      <div class="btn-row">
        <button class="btn btn-primary" onclick="submitForm('${tipo}')">💾 Salvar Consulta</button>
        <button class="btn btn-pdf" onclick="triggerPDF('${tipo}')">📄 Gerar Relatório PDF</button>
        <button class="btn btn-success" onclick="goToDietFromForm()">🥗 Abrir Plano Alimentar</button>
        <button class="btn btn-secondary" onclick="showPage('dashboard')">Cancelar</button>
      </div>
    </div>
  `;
  el.innerHTML = formHtml;
  if (data && Object.keys(data).length > 0) fillForm(data);
}

