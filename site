const MEAL_NAMES = ['Café da Manhã','Lanche da Manhã','Almoço','Lanche da Tarde','Jantar','Ceia'];

function addMeal() {
  const idx = mealsData.length;
  mealsData.push({ name: MEAL_NAMES[idx] || `Refeição ${idx+1}`, foods:[] });
  renderMeals();
}

function renderMeals() {
  const c = document.getElementById('meals-container');
  if (!c) return;
  c.innerHTML = mealsData.map((meal, mi) => `
    <div class="meal-card">
      <div class="meal-header" onclick="toggleMeal(${mi})">
        <h4>🍽 ${meal.name}</h4>
        <div style="display:flex;gap:12px;align-items:center;">
          <span class="kcal-badge" id="meal-kcal-${mi}">0 kcal</span>
          <button class="btn btn-danger btn-sm" onclick="event.stopPropagation();removeMeal(${mi})">×</button>
        </div>
      </div>
      <div class="meal-body" id="meal-body-${mi}">
        <div class="form-grid cols-3" style="margin-bottom:8px;font-size:11px;color:var(--text-mid);font-weight:400;letter-spacing:0.05em;text-transform:uppercase;">
          <span>Alimento</span><span>Qtd (g)</span><span>Kcal</span>
        </div>
        ${meal.foods.map((f, fi) => renderFoodRow(mi, fi, f)).join('')}
        <select onchange="addFoodFromDB(${mi}, this)" style="width:100%;margin-top:8px;padding:8px 12px;">
          <option value="">+ Adicionar alimento da lista...</option>
          ${FOOD_DB.map((f,i) => `<option value="${i}">${f.name} (${f.caseira})</option>`).join('')}
        </select>
        <div style="margin-top:8px;">
          <input type="text" placeholder="Ou digitê um alimento manualmente e pressione Enter" 
            onkeydown="if(event.key==='Enter'){addCustomFood(${mi},this.value);this.value=''}"
            style="width:100%;padding:7px 12px;font-size:13px;">
        </div>
        <div class="food-total" id="meal-total-${mi}"></div>
      </div>
    </div>
  `).join('');
  updateDietTotals();
}

function renderFoodRow(mi, fi, f) {
  return `
  <div class="food-row" id="fr-${mi}-${fi}">
    <input value="${f.name}" onchange="mealsData[${mi}].foods[${fi}].name=this.value;updateDietTotals()" style="background:var(--cream);">
    <input type="number" value="${f.grams||100}" step="1" min="0"
      onchange="mealsData[${mi}].foods[${fi}].grams=+this.value;recalcFood(${mi},${fi});updateDietTotals()">
    <input value="${calcFoodKcal(f)}" readonly style="background:var(--beige);color:var(--brown);">
    <span style="font-size:11px;color:var(--text-mid);">${f.caseira||''}</span>
    <button class="btn btn-danger btn-sm" style="padding:4px 8px;" onclick="removeFood(${mi},${fi})">×</button>
  </div>`;
}

function addFoodFromDB(mi, sel) {
  const idx = parseInt(sel.value);
  if (isNaN(idx)) return;
  const f = { ...FOOD_DB[idx], grams:100 };
  mealsData[mi].foods.push(f);
  sel.value = '';
  renderMeals();
}

function addCustomFood(mi, name) {
  if (!name.trim()) return;
  mealsData[mi].foods.push({ name:name.trim(), cho:0, ptn:0, lip:0, fiber:0, kcalPer100:0, grams:100, caseira:'' });
  renderMeals();
}

function removeFood(mi, fi) { mealsData[mi].foods.splice(fi,1); renderMeals(); }
function removeMeal(mi) { mealsData.splice(mi,1); renderMeals(); }
function toggleMeal(mi) {
  const b = document.getElementById('meal-body-'+mi);
  if (b) b.style.display = b.style.display === 'none' ? '' : 'none';
}

function calcFoodKcal(f) {
  const g = f.grams || 100;
  return Math.round(((f.cho||0)*4 + (f.ptn||0)*4 + (f.lip||0)*9) * g / 100);
}

function recalcFood(mi, fi) {}

function updateDietTotals() {
  let totalKcal=0, totalCHO=0, totalPTN=0, totalLIP=0, totalFiber=0;
  mealsData.forEach((meal, mi) => {
    let mKcal=0;
    meal.foods.forEach(f => {
      const g = f.grams || 100;
      const kcal = Math.round(((f.cho||0)*4+(f.ptn||0)*4+(f.lip||0)*9)*g/100);
      mKcal += kcal; totalKcal += kcal;
      totalCHO += (f.cho||0)*g/100;
      totalPTN += (f.ptn||0)*g/100;
      totalLIP += (f.lip||0)*g/100;
      totalFiber += (f.fiber||0)*g/100;
    });
    const kb = document.getElementById('meal-kcal-'+mi);
    if (kb) kb.textContent = Math.round(mKcal) + ' kcal';
    const mt = document.getElementById('meal-total-'+mi);
    if (mt) mt.textContent = `Total: ${Math.round(mKcal)} kcal`;
  });
  set('dm-kcal', Math.round(totalKcal));
  set('dm-cho', Math.round(totalCHO) + 'g');
  set('dm-ptn', Math.round(totalPTN) + 'g');
  set('dm-lip', Math.round(totalLIP) + 'g');
  set('dm-fiber', Math.round(totalFiber) + 'g');
}

function populateDietPatientSelect() {
  const sel = document.getElementById('diet-patient-select');
  if (!sel) return;
  sel.innerHTML = '<option value="">— Selecionar Paciente —</option>' +
    allPatients.map(p => `<option value="${p.id}">${p.nome||'Sem nome'} (${consultLabel(p.tipo)})</option>`).join('');
}

async function loadPatientForDiet() {
  const id = document.getElementById('diet-patient-select')?.value;
  if (!id || !db) return;
  const snap = await fbFns.getDoc(fbFns.doc(db, 'pacientes', id));
  if (!snap.exists()) return;
  const data = snap.data();
  const g = k => data['f_'+k] || data['f_'+k.replace(/-/g,'_')] || '';

  document.getElementById('patient-diet-info').style.display = 'block';
  document.getElementById('di-nome').textContent = g('nome') || 'Paciente';
  document.getElementById('di-get').textContent = data.r_vet_termico ? data.r_vet_termico + ' kcal' : '—';
  document.getElementById('di-meta').textContent = data.r_meta ? data.r_meta + ' kcal' : '—';
  document.getElementById('di-obs').textContent = [g('alergias'), g('estilo-alim'), g('gosta') ? 'Gosta: '+g('gosta') : '', g('nao-gosta') ? 'Não gosta: '+g('nao-gosta') : ''].filter(Boolean).join(' | ') || 'Sem restrições cadastradas';

  if (!mealsData.length) {
    mealsData = MEAL_NAMES.map(n => ({ name:n, foods:[] }));
    renderMeals();
  }
}

function goToDietFromForm() {
  showPage('dieta');
  populateDietPatientSelect();
  if (currentPatientId) {
    const sel = document.getElementById('diet-patient-select');
    if (sel) { sel.value = currentPatientId; loadPatientForDiet(); }
  }
  if (!mealsData.length) {
    mealsData = MEAL_NAMES.map(n => ({ name:n, foods:[] }));
    renderMeals();
  }
}

async function saveDiet() {
  const id = document.getElementById('diet-patient-select')?.value;
  if (!id || !db) { toast('⚠️ Selecione um paciente primeiro'); return; }
  try {
    const ref = fbFns.doc(db, 'pacientes', id);
    await fbFns.updateDoc(ref, { diet: mealsData, dietUpdatedAt: new Date().toISOString() });
    toast('✅ Plano alimentar salvo!');
  } catch(e) { toast('❌ Erro ao salvar plano'); }
}

function exportDietPDF() {
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF({ orientation:'portrait', unit:'mm', format:'a4' });
  const W = 210, margin = 18;
  const nome = document.getElementById('di-nome')?.textContent || 'Paciente';
  const meta = document.getElementById('di-meta')?.textContent || '';

  doc.setFillColor(74,53,37);
  doc.rect(0,0,W,38,'F');
  doc.setTextColor(232,221,208);
  doc.setFontSize(20); doc.setFont('helvetica','bold');
  doc.text('Plano Alimentar Personalizado', margin, 18);
  doc.setFontSize(11); doc.setFont('helvetica','normal');
  doc.text(`Paciente: ${nome} | Meta: ${meta} kcal/dia`, margin, 28);
  doc.setFontSize(9);
  doc.text(`Elaborado em: ${new Date().toLocaleDateString('pt-BR')}`, margin, 35);

  let y = 48;
  let totalKcal=0, totalCHO=0, totalPTN=0, totalLIP=0;

  mealsData.forEach(meal => {
    if (!meal.foods.length) return;
    if (y > 250) { doc.addPage(); y = 20; }

    doc.setFillColor(160,128,96);
    doc.rect(margin, y-4, W-margin*2, 8, 'F');
    doc.setTextColor(255,255,255);
    doc.setFontSize(11); doc.setFont('helvetica','bold');
    doc.text(meal.name, margin+3, y+1);
    y += 8;

    const rows = meal.foods.map(f => {
      const g = f.grams || 100;
      const kcal = Math.round(((f.cho||0)*4+(f.ptn||0)*4+(f.lip||0)*9)*g/100);
      const cho = ((f.cho||0)*g/100).toFixed(1);
      const ptn = ((f.ptn||0)*g/100).toFixed(1);
      const lip = ((f.lip||0)*g/100).toFixed(1);
      totalKcal+=kcal; totalCHO+=parseFloat(cho); totalPTN+=parseFloat(ptn); totalLIP+=parseFloat(lip);
      return [f.name, `${g}g`, f.caseira||'—', `${kcal}`, `${cho}g`, `${ptn}g`, `${lip}g`];
    });

    doc.autoTable({
      startY: y,
      head: [['Alimento','Qtd','Medida Caseira','Kcal','CHO','PTN','LIP']],
      body: rows,
      theme:'grid',
      headStyles:{ fillColor:[232,221,208], textColor:[74,53,37], fontSize:9 },
      bodyStyles:{ fontSize:9, textColor:[46,31,15] },
      alternateRowStyles:{ fillColor:[250,246,240] },
      margin:{ left:margin, right:margin }
    });
    y = doc.lastAutoTable.finalY + 6;
  });

  // Totals
  if (y > 260) { doc.addPage(); y = 20; }
  doc.autoTable({
    startY: y,
    head: [['TOTAL DIÁRIO','Calorias','Carboidratos','Proteínas','Lipídios']],
    body: [[nome, Math.round(totalKcal)+' kcal', totalCHO.toFixed(1)+'g', totalPTN.toFixed(1)+'g', totalLIP.toFixed(1)+'g']],
    theme:'grid',
    headStyles:{ fillColor:[74,53,37], textColor:[232,221,208], fontSize:10 },
    bodyStyles:{ fontSize:11, textColor:[74,53,37], fontStyle:'bold' },
    margin:{ left:margin, right:margin }
  });

  y = doc.lastAutoTable.finalY + 10;
  doc.setFontSize(9); doc.setTextColor(160,128,96); doc.setFont('helvetica','italic');
  doc.text('Este plano alimentar foi elaborado individualmente. Não compartilhe sem orientação profissional.', margin, y);

  const pages = doc.internal.getNumberOfPages();
  for(let i=1;i<=pages;i++){
    doc.setPage(i);
    doc.setFontSize(8); doc.setFont('helvetica','normal'); doc.setTextColor(160,128,96);
    doc.text(`NutriConsulta — Plano Alimentar — ${nome} — Página ${i}/${pages}`, margin, 290);
  }

  doc.save(`plano_alimentar_${nome.replace(/\s+/g,'_')}.pdf`);
  toast('📄 Plano exportado com sucesso!');
}

