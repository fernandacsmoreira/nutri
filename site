  doc.setFontSize(9);
  doc.text(`Data: ${new Date().toLocaleDateString('pt-BR')} | Tipo: ${consultLabel(data.tipo)}`, margin, 33);

  let y = 48;

  const addSection = (title) => {
    doc.setFillColor(232,221,208);
    doc.rect(margin, y-4, W-margin*2, 8, 'F');
    doc.setTextColor(74,53,37);
    doc.setFontSize(11);
    doc.setFont('helvetica','bold');
    doc.text(title, margin+2, y+1);
    y += 10;
    doc.setFont('helvetica','normal');
    doc.setTextColor(46,31,15);
    doc.setFontSize(10);
  };

  const addRow = (label, val) => {
    if (!val || val === '' || val === 'undefined') return;
    const text = `${label}: ${val}`;
    const lines = doc.splitTextToSize(text, W-margin*2);
    lines.forEach(l => {
      if (y > 270) { doc.addPage(); y = 20; }
      doc.text(l, margin, y);
      y += 6;
    });
  };

  const g = (k) => data['f_' + k.replace(/-/g,'_')] || '';

  addSection('IDENTIFICAÇÃO');
  addRow('Nome', g('nome')); addRow('Idade', g('idade') + (g('idade') ? ' anos' : '')); addRow('Sexo', g('sexo') === 'F' ? 'Feminino' : g('sexo') === 'M' ? 'Masculino' : '');
