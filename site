  addRow('Cintura', g('cintura') ? g('cintura') + ' cm' : ''); addRow('Quadril', g('quadril') ? g('quadril') + ' cm' : '');
  addRow('CB', g('cb') ? g('cb') + ' cm' : ''); addRow('PCT', g('pct') ? g('pct') + ' mm' : '');
  y += 3;

