  for (let i=1; i<=pages; i++) {
    doc.setPage(i);
    doc.text(`NutriConsulta — Documento clínico confidencial — Página ${i}/${pages}`, margin, 290);
  }

  const nome = data.f_nome || 'paciente';
  doc.save(`consulta_${nome.replace(/\s+/g,'_')}_${new Date().toLocaleDateString('pt-BR').replace(/\//g,'-')}.pdf`);
  toast('📄 PDF gerado com sucesso!');
}

